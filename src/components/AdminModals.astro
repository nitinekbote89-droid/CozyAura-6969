<!-- Product Modal -->
<div class="modal-overlay" id="productModal">
  <div class="modal">
    <div class="modal-header">
      <h3 id="modalTitle">Add New Product</h3>
      <button class="btn-close" type="button" onclick="window.closeModal()" style="background:transparent; border:none; cursor:pointer; color: var(--text-main);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <form id="productForm" onsubmit="window.handleProductSubmit(event)">
      <div class="form-group">
        <label>Product Name</label>
        <input type="text" id="prodName" required>
      </div>
      <div class="form-group">
        <label>Product Cover Picture</label>
        <div style="display: flex; align-items: center; justify-content: space-between; gap: 16px;">
          <input type="file" id="prodCoverImageInput" accept="image/*" onchange="window.handleCoverImageSelection(event)" style="border:none; padding:0; margin-bottom:0; flex: 1;">
          <div id="prodCoverImagePreview" style="position: relative; width: 80px; height: 80px; border: 1px solid var(--border); border-radius: 4px; display: flex; align-items: center; justify-content: center; overflow: hidden; background: var(--bg-main); flex-shrink: 0;">
            <span style="font-size: 0.75rem; color: var(--text-muted);">No Cover</span>
          </div>
        </div>
      </div>
      <div class="form-group">
        <label>Category</label>
        <select id="prodCategory" required onchange="window.handleCategoryChange(event)"></select>
      </div>
      <div class="form-group" id="customCategoryGroup" style="display: none;">
        <label>New Category Name</label>
        <input type="text" id="prodCategoryCustom" placeholder="e.g. Citrus">
      </div>
      
      <div class="form-group" style="border: 1px solid var(--border); padding: 16px; border-radius: 6px; background: var(--bg-main);">
        <label style="font-weight: 600; color: var(--brand); margin-bottom: 4px;">Fragrance Stock & Media Allocations</label>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 12px;">Toggle checkboxes to include fragrance configurations, assign inventory levels, and upload dedicated images.</p>
        <div id="prodFragrancesStockMatrix" style="display: flex; flex-direction: column; gap: 14px;"></div>
      </div>

      <div class="form-group">
        <label>Description</label>
        <textarea id="prodDesc" placeholder="Describe the scent notes..."></textarea>
      </div>
      <div class="form-group">
        <label>Specifications</label>
        <textarea id="prodSpecs" placeholder="e.g., Weight: 200g, Burn time: 40 hrs..."></textarea>
      </div>
      
      <!-- Flex Grid containing the Price and Actual Weight Fields -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
        <div class="form-group">
          <label>Price (₹)</label>
          <input type="number" id="prodPrice" required min="0">
        </div>
        <div class="form-group">
          <label>Actual Weight (grams)</label>
          <input type="number" id="prodWeight" required min="0" placeholder="e.g. 450">
        </div>
      </div>
      
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="window.closeModal()">Cancel</button>
        <button type="submit" class="btn btn-primary" id="modalSubmitBtn">Save Product</button>
      </div>
    </form>
  </div>
</div>

<!-- Coupon Modal -->
<div class="modal-overlay" id="couponModal">
  <div class="modal" style="max-width:400px;">
    <div class="modal-header">
      <h3>Create New Promo Code</h3>
      <button onclick="window.closeCouponModal()" style="background:transparent; border:none; cursor:pointer; display:flex; color: var(--text-main);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <form id="couponForm" onsubmit="window.handleCouponSubmit(event)">
      <div class="form-group">
        <label>Promo Code (Alphanumeric)</label>
        <input type="text" id="cpCode" placeholder="e.g. SUMMER50" required style="text-transform: uppercase;">
      </div>
      <div class="form-group">
        <label>Discount Type</label>
        <select id="cpType" required onchange="window.handleCouponTypeChange(this.value)" style="background: var(--bg-surface); color: var(--text-main); width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 6px; font-family: inherit; font-size: 0.95rem; outline: none; cursor: pointer;">
          <option value="percent">Percentage Off (%)</option>
          <option value="fixed">Flat Rs Off (₹)</option>
          <option value="freeship">Free Shipping</option>
        </select>
      </div>
      <div class="form-group" id="cpDiscountGroup">
        <label id="cpDiscountLabel">Discount Value (%)</label>
        <input type="number" id="cpDiscount" min="1" max="100" placeholder="e.g. 15" required>
      </div>
      <div class="form-group">
        <label>Minimum Order Value (₹)</label>
        <input type="number" id="cpMinOrderValue" min="0" value="0" placeholder="e.g. 500 (Optional)">
      </div>
      <div class="form-group">
        <label>Scope / Visibility</label>
        <select id="cpScope" required style="background: var(--bg-surface); color: var(--text-main); width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 6px; font-family: inherit; font-size: 0.95rem; outline: none; cursor: pointer;">
          <option value="public">Public (Visible to everyone)</option>
          <option value="private">Private (Targeted / Hidden)</option>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="window.closeCouponModal()">Cancel</button>
        <button type="submit" class="btn btn-primary">Activate Coupon</button>
      </div>
    </form>
  </div>
</div>

<!-- Order Receipt Modal -->
<div class="modal-overlay" id="orderModal" style="z-index: 1300;">
  <div class="modal" style="max-width: 800px;">
    <div class="modal-header">
      <h3>Order Receipt <span id="modalOrderId" style="color:var(--text-muted); font-weight:400;"></span></h3>
      <button onclick="window.closeOrderModal()" style="background:transparent; border:none; cursor:pointer; display:flex; color: var(--text-main);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <!-- Loader View -->
    <div id="orderModalLoader" style="display:none; flex-direction:column; align-items:center; justify-content:center; padding:64px; color:var(--text-muted); gap:16px;">
      <div class="spinner-gold-mini" style="width:24px; height:24px; border:2px solid rgba(184, 151, 90, 0.2); border-top-color:#b8975a; border-radius:50%; animation:spinCircle 0.8s linear infinite;"></div>
      <div style="font-size:0.9rem; font-weight:500;">Loading order details...</div>
    </div>
    <!-- Main Modal Content -->
    <div id="orderModalContent" style="display: block;">
      <!-- Tracking Section -->
      <div id="modalTrackingSection" style="margin-bottom:1.5rem; padding-bottom:1.5rem; border-bottom:1px solid var(--border);">
        <h4 style="font-weight:500; margin-bottom:12px; font-size:0.9rem; color:var(--text-muted); text-transform:uppercase; letter-spacing:0.05em;">Courier & Tracking Information</h4>
        <div id="modalTrackingFields" style="display:grid; grid-template-columns: 1fr 1fr; gap:16px; margin-bottom:16px;">
          <div>
            <label style="display:block; font-size:0.75rem; color:var(--text-muted); margin-bottom:4px; text-transform:uppercase;">Courier Name</label>
            <input type="text" id="modalCourierInput" placeholder="e.g. BlueDart" style="background:var(--bg-main); color:var(--text-main); width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">
          </div>
          <div>
            <label style="display:block; font-size:0.75rem; color:var(--text-muted); margin-bottom:4px; text-transform:uppercase;">Tracking ID</label>
            <input type="text" id="modalTrackingInput" placeholder="e.g. AW1294819" style="background:var(--bg-main); color:var(--text-main); width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">
          </div>
        </div>
        <div>
          <label style="display:block; font-size:0.75rem; color:var(--text-muted); margin-bottom:4px; text-transform:uppercase;">Tracking Link</label>
          <input type="text" id="modalTrackingLinkInput" placeholder="e.g. https://delhivery.com/track/package/..." style="background:var(--bg-main); color:var(--text-main); width:100%; padding:8px 12px; border:1px solid var(--border); border-radius:6px; font-family:inherit;">
        </div>
      </div>

      <div style="display:grid; grid-template-columns:1fr 1.2fr; gap:24px; margin-bottom:24px;">
        <div>
          <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">Customer Information</strong>
          <p id="orderModalCustomer" style="font-weight:500; text-transform:capitalize;"></p>
          <p id="orderModalEmail" style="font-size:0.85rem; color:var(--text-muted); margin-top:2px;"></p>
          <p id="orderModalPhone" style="font-size:0.85rem; color:var(--text-muted); margin-top:2px;"></p>
        </div>
        <div>
          <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:8px;">Order Logistics</strong>
          <div style="display:grid; grid-template-columns:1fr 1fr; gap:12px;">
            <div>
              <label style="font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; display:block;">Purchase Date</label>
              <p id="orderModalDate" style="font-weight:500;"></p>
            </div>
            <div>
              <label style="font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; display:block;">Payment Info</label>
              <p id="orderModalPayment" style="font-weight:500;">COD / Pay on Delivery</p>
            </div>
          </div>
          <div style="margin-top:10px;">
            <label style="font-size:0.75rem; color:var(--text-muted); text-transform:uppercase; display:block; margin-bottom:4px;">Fulfillment Status</label>
            <span id="orderModalStatus"></span>
          </div>
        </div>
      </div>
      <div style="margin-bottom:24px; padding:16px; background:var(--bg-main); border:1px solid var(--border); border-radius:6px;">
        <p id="orderModalAddressLabel" style="color:var(--text-muted); font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:2px;">Shipping Address</p>
        <p id="orderModalAddress" style="font-weight:400; font-size:0.9rem;"></p>
      </div>
      <div class="table-container" style="max-height:220px; overflow-y:auto; margin-bottom:24px;">
        <table style="width:100%; border-collapse:collapse; font-size:0.9rem;">
          <thead>
            <tr style="background:var(--bg-main);">
              <th style="padding:10px 16px;">Product Details</th>
              <th style="padding:10px 16px;">Category</th>
              <th style="padding:10px 16px;">Rate</th>
              <th style="padding:10px 16px;">Qty</th>
              <th style="padding:10px 16px; text-align:right;">Subtotal</th>
            </tr>
          </thead>
          <tbody id="orderItemsBody"></tbody>
        </table>
      </div>
      <div style="display:flex; flex-direction:column; gap:8px; align-items:flex-end; font-size:0.9rem; padding-right:12px; margin-bottom:24px;">
         <div id="orderModalSubtotalRow" style="color:var(--text-muted);"></div>
         <div id="orderModalShippingRow" style="color:var(--text-muted);"></div>
         <div id="orderModalPromoRow" style="color:var(--success); font-weight:500;"></div>
         <div style="font-size:1.15rem; font-weight:700; color:var(--text-main); border-top:1px solid var(--border); padding-top:8px; margin-top:4px; width:220px; text-align:right;">
        Gross Total: <span id="orderModalTotal"></span>
         </div>
      </div>
      <div class="modal-footer" style="padding-top:16px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; gap:12px;">
        <button type="button" class="btn btn-primary" onclick="window.downloadInvoiceBill()">Download Bill</button>
        <button type="button" class="btn btn-secondary" onclick="window.closeOrderModal()">Dismiss Window</button>
      </div>
    </div>
  </div>
</div>

<!-- Feedback Modal -->
<div class="modal-overlay" id="feedbackDetailModal">
  <div class="modal" style="max-width: 500px;">
    <div class="modal-header">
      <h3>Customer Feedback / Review Message</h3>
      <button onclick="window.closeFeedbackModal()" style="background:transparent; border:none; cursor:pointer; display:flex; color: var(--text-main);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div style="display:flex; flex-direction:column; gap:16px; margin-top:16px; font-size:0.95rem; line-height:1.6; color:var(--text-main);">
      <div>
        <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Customer Identity</strong>
        <span id="feedbackModalCustomerName" style="font-weight:600;"></span> 
        <span id="feedbackModalCustomerEmail" style="color:var(--text-muted); font-size:0.9rem; margin-left:8px;"></span>
      </div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">
        <div>
          <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Order ID</strong>
          <span id="feedbackModalOrderId" style="font-family:monospace; font-weight:600;"></span>
        </div>
        <div>
          <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Rating Score</strong>
          <span id="feedbackModalRating" style="color:#FFC107; font-weight:bold; font-size:1.15rem; letter-spacing:1px;"></span>
        </div>
      </div>
      <div>
        <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:4px;">Purchased Items</strong>
        <span id="feedbackModalPurchasedItems" style="font-weight:500; font-size:0.92rem; color:var(--text-main);"></span>
      </div>
      <div style="border-top:1px solid var(--border); padding-top:16px;">
        <strong style="color:var(--brand); display:block; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:6px;">Written Comment / Feedback</strong>
        <div id="feedbackModalComment" style="background:var(--bg-main); padding:16px; border-radius:6px; border:1px solid var(--border); white-space:pre-wrap; font-style:italic;"></div>
      </div>
    </div>
    <div class="modal-footer" style="margin-top:24px; padding-top:16px; border-top:1px solid var(--border); display:flex; justify-content:flex-end;">
      <button type="button" class="btn btn-secondary" onclick="window.closeFeedbackModal()">Dismiss Window</button>
    </div>
  </div>
</div>

<!-- Customer Details Modal -->
<div class="modal-overlay" id="customerDetailModal" style="z-index: 1200;">
  <div class="modal" style="max-width: calc(100% - 48px); width: calc(100% - 48px); max-height: calc(100% - 48px); height: calc(100% - 48px); display: flex; flex-direction: column;">
    <div class="modal-header" style="flex-shrink: 0;">
      <h3>Customer Account Profile</h3>
      <button onclick="window.closeCustomerDetailModal()" style="background:transparent; border:none; cursor:pointer; display:flex; color: var(--text-main);">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
    </div>
    <div id="customerDetailModalBody" style="display:flex; flex-direction:column; gap:20px; margin-top:16px; font-size:0.95rem; line-height:1.6; color:var(--text-main); flex: 1; min-height: 0; overflow-y: auto; padding-right: 6px;">
      <!-- Loaded dynamically -->
    </div>
    <div class="modal-footer" style="margin-top:auto; padding-top:16px; border-top:1px solid var(--border); display:flex; justify-content:flex-end; flex-shrink: 0;">
      <button type="button" class="btn btn-secondary" onclick="window.closeCustomerDetailModal()">Dismiss Window</button>
    </div>
  </div>
</div>
