---
import '/src/styles/global.css';

const paytmMid = import.meta.env.PAYTM_MID || process.env.PAYTM_MID || '';
const paytmEnvironment = import.meta.env.PAYTM_ENVIRONMENT || process.env.PAYTM_ENVIRONMENT || 'stage';
const paytmHost = paytmEnvironment === 'prod' ? 'https://securegw.paytm.in' : 'https://securegw-stage.paytm.in';
const paytmScriptUrl = paytmMid ? `${paytmHost}/merchantpgpui/checkoutjs/merchants/${paytmMid}.js` : '';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cozy Aura Candle | Premium Hand-Poured Soy Wax Candles</title>
  <meta name="description" content="Discover premium hand-poured soy wax candles by Cozy Aura Candle. Thoughtfully crafted with elegant fragrances to create warmth, comfort, and timeless moments in every home." />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="shortcut icon" href="/favicon.png" />
  <link rel="canonical" href="https://cozyaura.in/" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Cozy Aura Candle" />
  <meta property="og:title" content="Cozy Aura Candle | Premium Hand-Poured Soy Wax Candles" />
  <meta property="og:description" content="Discover premium hand-poured soy wax candles by Cozy Aura Candle. Thoughtfully crafted with elegant fragrances to create warmth, comfort, and timeless moments in every home." />
  <meta property="og:url" content="https://cozyaura.in/" />
  <meta property="og:image" content="https://cozyaura.in/favicon.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Cozy Aura Candle | Premium Hand-Poured Soy Wax Candles" />
  <meta name="twitter:description" content="Discover premium hand-poured soy wax candles by Cozy Aura Candle. Thoughtfully crafted with elegant fragrances to create warmth, comfort, and timeless moments in every home." />
  <meta name="twitter:image" content="https://cozyaura.in/favicon.png" />
  <link rel="preconnect" href="https://res.cloudinary.com" crossorigin>
  {paytmMid && <link rel="preconnect" href={paytmHost} crossorigin>}
  <link rel="preload" href="/fonts/cormorant-garamond-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/cormorant-garamond-latin-italic.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/jost-latin.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="stylesheet" href="/fonts.css" />
  <slot name="head" />
  {paytmScriptUrl && <script type="application/javascript" src={paytmScriptUrl} crossorigin="anonymous" defer></script>}
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CozyAura",
    "url": "https://cozyaura.in/",
    "description": "Hand-poured 100% natural soya candles crafted in small batches.",
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "hello@cozyaura.in",
      "telephone": "+91-98765-43210",
      "contactType": "customer service"
    }
  }
  </script>
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CozyAura",
    "url": "https://cozyaura.in/"
  }
  </script>
</head>
<body>
  <slot />
</body>
</html>
