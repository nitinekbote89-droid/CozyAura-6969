---
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---
<html><body>
<script is:inline>
  var SUPABASE_URL = '{supabaseUrl}';
  var SUPABASE_KEY = '{supabaseKey}';

  (async () => {
    try {
      var params = new URLSearchParams(window.location.search);
      var errMsg = params.get('error_description') || params.get('error');
      if (errMsg) {
        window.location.href = '/?auth_error=' + encodeURIComponent(errMsg);
        return;
      }

      var code = params.get('code');
      if (!code) {
        window.location.href = '/?auth_error=' + encodeURIComponent('No auth code received');
        return;
      }

      // Retrieve code_verifier from localStorage (set by supabase during signInWithOAuth)
      var storageKey = null;
      for (var i = 0; i < localStorage.length; i++) {
        var key = localStorage.key(i);
        if (key && key.indexOf('code-verifier') !== -1) {
          storageKey = key;
          break;
        }
      }
      var codeVerifier = storageKey ? JSON.parse(localStorage.getItem(storageKey)) : null;

      // Exchange code for session via Supabase REST API
      var bodyData = { grant_type: 'authorization_code', code: code };
      if (codeVerifier) bodyData.code_verifier = codeVerifier;
      if (!codeVerifier) bodyData.redirect_uri = window.location.origin + '/auth/callback';

      var tokenRes = await fetch(SUPABASE_URL + '/auth/v1/token', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_KEY },
        body: JSON.stringify(bodyData)
      });

      if (!tokenRes.ok) {
        window.location.href = '/?auth_error=' + encodeURIComponent('Failed to exchange auth code');
        return;
      }

      var tokenData = await tokenRes.json();
      if (!tokenData.access_token) {
        window.location.href = '/?auth_error=' + encodeURIComponent('No access token received');
        return;
      }

      // Store session in localStorage so main page can detect it
      var sbKey = null;
      for (var j = 0; j < localStorage.length; j++) {
        var k = localStorage.key(j);
        if (k && k.indexOf('sb-') !== -1 && k.indexOf('auth-token') !== -1) {
          sbKey = k;
          break;
        }
      }
      if (sbKey) {
        localStorage.setItem(sbKey, JSON.stringify(tokenData));
      }

      // Fetch user metadata
      var userRes = await fetch(SUPABASE_URL + '/auth/v1/user', {
        headers: { 'Authorization': 'Bearer ' + tokenData.access_token, 'apikey': SUPABASE_KEY }
      });
      var userData = userRes.ok ? await userRes.json() : null;

      var email = (userData && userData.email) || '';
      var name = (userData && userData.user_metadata && userData.user_metadata.full_name) || email.split('@')[0] || 'User';
      var avatar = (userData && userData.user_metadata && userData.user_metadata.avatar_url) || '';
      var qs = new URLSearchParams({ user_email: email, user_name: name });
      if (avatar) qs.set('user_avatar', avatar);
      window.location.href = '/?' + qs.toString();
    } catch (err) {
      window.location.href = '/?auth_error=' + encodeURIComponent(err.message || 'Sign in failed');
    }
  })();
</script>
</body></html>