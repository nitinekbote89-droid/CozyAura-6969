                  <button type="button" class="label-btn" onclick="window.setAddressLabel('Work')" id="labelBtnWork" style="flex:1; padding:0.6rem; border:1px solid var(--sand); background:white; cursor:pointer; font-size:0.75rem; font-family:inherit; text-transform:uppercase; letter-spacing:0.05em; border-radius:2px; font-weight:500; transition:all 0.3s;">Work</button>
                  <button type="button" class="label-btn" onclick="window.setAddressLabel('Other')" id="labelBtnOther" style="flex:1; padding:0.6rem; border:1px solid var(--sand); background:white; cursor:pointer; font-size:0.75rem; font-family:inherit; text-transform:uppercase; letter-spacing:0.05em; border-radius:2px; font-weight:500; transition:all 0.3s;">Other</button>
                </div>
              </fieldset>
              <div class="form-group" style="display:flex; align-items:center; gap:8px; margin-bottom:1.2rem;">
                <input type="checkbox" id="isAddressDefault" style="width:auto; height:auto; margin:0; cursor:pointer;" />
                <label for="isAddressDefault" style="margin:0; font-size:0.8rem; cursor:pointer; text-transform:none; letter-spacing:normal; color:var(--charcoal);">Save as default address</label>
              </div>
            </div>

            <!-- Default proceed button for guest / basic flow -->
            <button type="button" id="guestProceedBtn" class="btn-primary proceed-btn" onclick="window.proceedToPayment()" style="padding:1rem 2.5rem; margin-top:1.5rem; width:100%; cursor:pointer;">Continue to Payment <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">arrow_forward</span></button>

            <!-- Save Address buttons for logged-in user editing -->
            <div id="addressFormActions" style="display:none; gap:10px; margin-top:1.5rem;">
              <button type="button" class="btn-primary" onclick="window.cancelAddressForm()" onmouseover="this.style.background='var(--cream)';" onmouseout="this.style.background='white';" style="flex:1; background:white; color:var(--stone); border:1px solid var(--sand); padding:1rem; cursor:pointer; font-family:inherit; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; border-radius:2px; transition:all 0.3s;">Cancel</button>
              <button type="button" class="btn-primary" onclick="window.saveAddressForm()" style="flex:2; padding:1rem; cursor:pointer; font-family:inherit; font-size:0.8rem; text-transform:uppercase; letter-spacing:0.05em; border-radius:2px;">Save Address</button>
            </div>
          </form>
        </div>

        <!-- Step 2: Shipping Method + Payment + Billing Address -->
        <div id="paymentScreenContainer" style="display: none;">
          <!-- Shipping Summary Card -->
          <div class="checkout-summary-card">
            <div class="summary-card-row">
              <span class="card-label">Contact</span>
              <span class="card-value" id="summaryContactValue"></span>
            </div>
            <div class="summary-card-row">
              <span class="card-label">Ship to</span>
              <span class="card-value" id="summaryAddressValue"></span>
            </div>
          </div>

          <!-- Shipping Method Section -->
          <div class="checkout-section">
            <h3 class="checkout-section-title">Shipping method</h3>
            <div class="shipping-method-box">
              <span class="shipping-method-name">Standard Shipping</span>
              <span class="shipping-method-price">₹150.00</span>
            </div>
          </div>

          <!-- Payment Section -->
          <div class="checkout-section">
            <h3 class="checkout-section-title" style="margin-bottom:0.25rem;">Payment</h3>
            <p class="checkout-section-subtitle">All transactions are secure and encrypted.</p>
            
            <div class="payment-options-group">
              <!-- Razorpay Secure Option -->
              <div class="payment-option-card active" onclick="window.setPaymentMethod('Online')">
                <div class="payment-option-header">
                  <label class="payment-radio-label-custom">
                    <input type="radio" name="paymentMethodSelect" value="Online" checked />
                    <span class="radio-custom-circle"></span>
                    <span class="payment-method-title">Razorpay Secure (UPI, Cards, Int'l Cards, Wallets)</span>
                  </label>
                  <div class="payment-icons">
                    <svg viewBox="0 0 34 18" width="28" height="15" style="border:1px solid #e2e8f0; border-radius:2px; padding:2px; background:white; vertical-align:middle; margin-right:3px;">
                      <text x="50%" y="60%" dominant-baseline="middle" text-anchor="middle" font-family="'Jost', sans-serif" font-size="8" font-weight="900" fill="#097939">UPI</text>
                    </svg>
                    <svg viewBox="0 0 24 15" width="24" height="15" style="border-radius:2px; vertical-align:middle; margin-right:3px;">
                      <rect width="24" height="15" fill="#1A1F71" />
                      <text x="50%" y="65%" dominant-baseline="middle" text-anchor="middle" font-family="sans-serif" font-size="8" font-weight="bold" font-style="italic" fill="#F7B614">VISA</text>
                    </svg>
                    <svg viewBox="0 0 24 15" width="24" height="15" style="border-radius:2px; vertical-align:middle; margin-right:3px;">
                      <rect width="24" height="15" fill="#222" />
                      <circle cx="10" cy="7.5" r="5" fill="#EB001B" />
                      <circle cx="14" cy="7.5" r="5" fill="#FF5F00" opacity="0.8" />
                    </svg>
                    <span class="more-payments-badge">+17</span>
                  </div>
                </div>
                <div class="payment-option-body" id="razorpayOptionBody">
                  <p>You'll be redirected to Razorpay Secure (UPI, Cards, Int'l Cards, Wallets) to complete your purchase.</p>
                </div>
              </div>

              <!-- COD Option -->
              <div class="payment-option-card" onclick="window.setPaymentMethod('COD')">
                <div class="payment-option-header">
                  <label class="payment-radio-label-custom">
                    <input type="radio" name="paymentMethodSelect" value="COD" />
                    <span class="radio-custom-circle"></span>
                    <span class="payment-method-title">Cash on Delivery (COD)</span>
                  </label>
                </div>
                <div class="payment-option-body" id="codOptionBody" style="display: none;">
                  <p>Pay with cash upon delivery of your order. A COD confirmation will be sent.</p>
                </div>
              </div>
            </div>
          </div>



          <!-- Final Pay Now button -->
          <button class="pay-now-btn" onclick="window.executeSecurePayment()">Pay now</button>
        </div>
      </div>

      <!-- Right Column: Order Summary Sidebar -->
      <div class="checkout-sidebar-content">
        <div class="checkout-sidebar-inner">
          <h3 style="margin: 0 0 1.5rem 0; font-family:'Jost',sans-serif; font-size:0.9rem; letter-spacing:0.12em; text-transform:uppercase; color:var(--black); font-weight:500; border-bottom:1px solid var(--sand); padding-bottom:0.75rem;">Summary</h3>
          <!-- Items List -->
          <div class="checkout-items-list" id="checkoutSidebarItems">
            <!-- Dynamically populated from JS -->
          </div>

          <!-- Discount Input Box -->
          <div class="checkout-discount-box">
            <input type="text" id="checkoutDiscountInput" placeholder="Discount code or gift card" />
            <button onclick="window.applyCheckoutDiscount()" id="checkoutDiscountApplyBtn">Apply</button>
          </div>
          <!-- Applied Promo Badge / info if any -->
          <div id="checkoutAppliedPromoContainer"></div>

          <!-- Breakdown summary -->
          <div class="checkout-breakdown">
            <div class="breakdown-row">
              <span>Subtotal</span>
              <span id="checkoutSidebarSubtotal">₹0.00</span>
            </div>
            <div class="breakdown-row">
              <span>Shipping</span>
              <span id="checkoutSidebarShipping">Enter shipping address</span>
            </div>
            <div class="breakdown-row discount-row" id="checkoutSidebarDiscountRow" style="display: none;">
              <span>Discount</span>
              <span id="checkoutSidebarDiscount">-₹0.00</span>
            </div>
            <div class="breakdown-row total-row">
              <div class="total-label-wrap">
                <span class="total-main-label">Total</span>
                <span class="total-sub-label" id="checkoutSidebarTaxLabel" style="display: none;">Including ₹0.00 in taxes</span>
              </div>
              <div class="total-price-wrap">
                <span class="currency-code">INR</span>
                <span class="total-main-price" id="checkoutSidebarTotal">₹0.00</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
