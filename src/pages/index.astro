        <div id="promoContainer"></div>
        <div class="summary-line"><span>Subtotal</span><span id="summarySubtotal">₹0</span></div>
        <div class="summary-line" style="display: none;"><span>Shipping Freight</span><span id="summaryShipping">₹0</span></div>
        <div class="summary-line" id="summaryPromoLine" style="display:none;"><span>Promo</span><span id="summaryPromo">—</span></div>
        <div class="summary-line total"><span>Total</span><span id="summaryTotal">₹0</span></div>
        <button class="btn-primary" onclick="window.goToCheckout()" style="width:100%; margin-top:1.5rem; padding: 1rem 2rem;">Proceed to Checkout <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">arrow_forward</span></button>
      </div>
    </div>
  </section>

  <section id="payment" class={initialPage === 'payment' ? 'active' : ''}>





    <div class="checkout-container">
      <div class="checkout-main-content">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
          <button onclick="window.goBackToCart()" class="back-to-cart-btn" style="background:none;border:none;cursor:pointer;color:var(--stone);font-family:inherit;font-size:0.8rem;display:flex;align-items:center;gap:0.3rem;padding:0;"><span class="material-symbols-outlined" style="font-size:16px;">arrow_back</span> Back to Cart</button>
          <h2 style="margin:0;font-size:1.8rem;font-weight:300;"><em>Checkout</em></h2>
          <div></div>
        </div>

        <!-- Step 1: Shipping Address Form -->
        <div id="deliveryFormContainer">
          <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:1.2rem; flex-wrap:wrap; gap:10px;">
            <h3 class="checkout-section-title" style="margin:0;font-family:'Jost',sans-serif;font-size:0.88rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--black);font-weight:500;">Delivery Address</h3>
            <button type="button" id="googleAutofillBtn" onclick="window.checkoutGoogleLogin()" onmouseover="this.style.background='var(--cream)'; this.style.borderColor='var(--stone)';" onmouseout="this.style.background='white'; this.style.borderColor='var(--sand)';" style="display:none; align-items:center; gap:8px; background:white; border:1px solid var(--sand); padding: 8px 16px; font-size:0.75rem; cursor:pointer; font-family:'Jost',sans-serif; letter-spacing:0.08em; text-transform:uppercase; color:var(--charcoal); transition:all 0.3s; border-radius:2px;">
              <svg width="14" height="14" viewBox="0 0 24 24" style="vertical-align:middle;">
                <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
                <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
              </svg>
              <span>Autofill with Google</span>
            </button>
          </div>
          <!-- Saved Addresses Selection (Zomato-style) -->
          <div id="savedAddressesSection" style="display:none; margin-bottom:1.5rem;">
            <div class="saved-addresses-grid" id="savedAddressesGrid" style="display:grid; grid-template-columns: 1fr; gap:16px; margin-bottom:1.5rem;">
              <!-- Cards dynamically inserted here -->
            </div>
            <button type="button" class="btn-primary" onclick="window.showNewAddressForm()" onmouseover="this.style.background='var(--cream)';" onmouseout="this.style.background='white';" style="background:white; color:var(--charcoal); border:1px solid var(--sand); width:100%; padding:0.8rem; font-size:0.75rem; margin-bottom:1rem; letter-spacing:0.08em; text-transform:uppercase; cursor:pointer; font-family:'Jost',sans-serif; border-radius:2px; transition:all 0.3s;">+ Add New Address</button>
            <button type="button" class="btn-primary proceed-btn" onclick="window.proceedToPayment()" style="padding:1rem 2.5rem; width:100%; cursor:pointer;">Continue to Payment <span class="material-symbols-outlined" style="font-size:14px;vertical-align:middle;">arrow_forward</span></button>
          </div>

          <form id="checkoutForm" class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label for="fname">First name</label>
                <input type="text" id="fname" autocomplete="given-name" required/>
              </div>
              <div class="form-group">
                <label for="lname">Last name</label>
                <input type="text" id="lname" autocomplete="family-name" required/>
              </div>
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" autocomplete="email" required/>
            </div>
            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="text" id="phone" autocomplete="tel" inputMode="numeric" maxlength="14" required/>
            </div>
            <div class="form-group">
              <label for="address">Address</label>
              <input type="text" id="address" autocomplete="street-address" required/>
            </div>
            <div class="form-group">
              <label for="pincode">Pincode</label>
              <input type="text" id="pincode" autocomplete="postal-code" maxlength="6" required/>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="city">City</label>
                <input type="text" id="city" autocomplete="address-level2" required/>
              </div>
              <div class="form-group">
                <label for="state">State</label>
                <input type="text" id="state" autocomplete="address-level1" required/>
              </div>
            </div>

            <!-- Zomato-style Label and Default options -->
            <div id="addressMetaFields" style="display:none; margin-top:1.2rem;">
              <fieldset class="form-group" style="margin-bottom:1.2rem; border:none; padding:0;">
