  <script is:inline>
  window.addEventListener('error', function(e) {
    const div = document.createElement('div');
    div.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#fecaca;color:#b91c1c;padding:1.25rem;z-index:9999;font-size:0.85rem;font-family:monospace;border-bottom:2px solid #ef4444;box-shadow:0 4px 20px rgba(0,0,0,0.1)';
    div.innerHTML = '<strong>Client Error:</strong> ' + e.message + ' <br><small style="opacity:0.8;">at ' + (e.filename||'unknown') + ':' + (e.lineno||0) + ':' + (e.colno||0) + '</small>';
    document.body.appendChild(div);
  });
  window.addEventListener('unhandledrejection', function(e) {
    const div = document.createElement('div');
    div.style.cssText = 'position:fixed;top:0;left:0;right:0;background:#fde047;color:#854d0e;padding:1.25rem;z-index:9999;font-size:0.85rem;font-family:monospace;border-bottom:2px solid #eab308;box-shadow:0 4px 20px rgba(0,0,0,0.1)';
    div.innerHTML = '<strong>Promise Rejection:</strong> ' + (e.reason ? (e.reason.message||e.reason) : 'Unknown rejection reason');
    document.body.appendChild(div);
  });
  </script>
