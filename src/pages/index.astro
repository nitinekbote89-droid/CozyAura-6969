        color: #b84d4d;
      }
      .builder-btn.btn-danger:hover {
        background: #f6e6e6;
      }

      /* Responsive styling for smaller laptop viewports */
      @media (max-height: 760px) {
        .gift-card-modal {
          height: 94vh;
          padding: 1rem 2rem;
        }
        canvas#cardCanvas {
          max-height: 500px;
        }
      }
      @media (max-height: 650px) {
        .gift-card-modal {
          height: 95vh;
          padding: 0.75rem 1.5rem;
        }
        .gift-card-modal .section-header {
          margin-bottom: 0.5rem !important;
        }
        .gift-card-modal .section-header h2 {
          font-size: 1.8rem !important;
        }
        .gift-card-modal p {
          margin-bottom: 0.75rem !important;
        }
      }
      @media (max-width: 768px) {
        .gift-card-modal .section-header {
          display: none !important;
        }
        .gift-card-modal {
          padding: 10px !important;
          height: 96vh !important;
          max-height: 96vh !important;
          display: flex !important;
          flex-direction: column !important;
          justify-content: space-between !important;
          overflow: hidden !important;
          border-radius: 0 !important;
        }
        .card-builder-container {
          display: flex !important;
          flex-direction: column-reverse !important;
          gap: 8px !important;
          height: 100% !important;
          margin: 0 !important;
          overflow: hidden !important;
        }
        .builder-canvas-area {
          flex: 0 0 auto !important;
          width: 100% !important;
          min-width: 100% !important;
          padding: 0 !important;
          margin: 0 !important;
          border: none !important;
          display: flex !important;
          flex-direction: column !important;
          align-items: center !important;
        }
        .canvas-frame {
          padding: 6px !important;
          border-radius: 8px !important;
        }
        canvas#cardCanvas {
          height: 260px !important;
          width: 130px !important;
          max-height: 260px !important;
        }
        .canvas-hint {
          display: none !important;
        }
        .builder-sidebar {
          flex: 1 1 auto !important;
          min-width: 100% !important;
          width: 100% !important;
          height: auto !important;
          max-height: 310px !important;
          margin: 0 !important;
          padding: 10px !important;
          overflow-y: auto !important;
          box-sizing: border-box !important;
        }
        .builder-section {
          margin-bottom: 8px !important;
        }
        .builder-section h3 {
          font-size: 0.85rem !important;
          margin-bottom: 6px !important;
        }
        .template-grid {
          gap: 8px !important;
          padding: 2px 0 !important;
        }
        .template-thumb {
          width: 56px !important;
          height: 56px !important;
          border-radius: 50% !important;
          padding: 2px !important;
          background: white !important;
        }
        .template-thumb:hover, .template-thumb.active {
          border-color: var(--gold-dark) !important;
          transform: scale(1.05) !important;
        }
        .sticker-grid {
          gap: 6px !important;
        }
        .sticker-item {
          width: 34px !important;
          height: 34px !important;
          font-size: 1.1rem !important;
        }
        .builder-actions-grid {
          margin-top: 8px !important;
          gap: 4px !important;
        }
        .builder-btn {
          padding: 6px 8px !important;
          font-size: 0.75rem !important;
        }
      }
    </style>

    <div class="card-builder-container">
      <!-- Control Sidebar -->
      <div class="builder-sidebar">
        <!-- Sidebar Tabs -->
        <div class="sidebar-tabs" style="display: flex; gap: 8px; margin-bottom: 12px; border-bottom: 1px solid rgba(196,181,160,0.2); padding-bottom: 8px;">
          <button type="button" id="tabBtnDesign" class="sidebar-tab-btn" onclick="window.switchSidebarTab('design')" style="flex: 1; padding: 6px; border: none; background: transparent; font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; cursor: pointer; border-bottom: 2px solid var(--gold-dark); color: var(--gold-dark); outline: none;">Design</button>
          <button type="button" id="tabBtnText" class="sidebar-tab-btn" onclick="window.switchSidebarTab('text')" style="flex: 1; padding: 6px; border: none; background: transparent; font-family: 'Jost', sans-serif; font-size: 0.8rem; font-weight: 600; text-transform: uppercase; cursor: pointer; border-bottom: 2px solid transparent; color: var(--stone); outline: none;">Text Message</button>
        </div>

        <!-- Design Tab Content -->
        <div id="sidebarTabDesign">
          <!-- 1. Templates Selection -->
          <div class="builder-section">
            <h3>1. Choose Card Template</h3>
             <div class="template-grid">
              {initialCatalog?.cardTemplates && initialCatalog.cardTemplates.length > 0 ? (
                initialCatalog.cardTemplates.map((t, idx) => (
                  <img 
                    class={`template-thumb ${idx === 0 ? 'active' : ''}`} 
                    src={t.image_url} 
                    onclick={`window.changeCardTemplate('${t.image_url}', this)`} 
                    alt={t.name}
                  />
                ))
              ) : (
                <p style="grid-column: span 3; font-size: 0.85rem; color: var(--text-muted); text-align: center; margin: 8px 0;">No templates uploaded yet. Add them in the Admin Portal.</p>
              )}
            </div>
          </div>

          <!-- 3. Sticker Panel -->
          <div class="builder-section" style="margin-bottom: 0;">
            <h3>2. Choose Stickers</h3>
            <div class="sticker-grid" style="display: flex; gap: 10px; flex-wrap: wrap;">
              {initialCatalog?.stickers && initialCatalog.stickers.length > 0 ? (
                initialCatalog.stickers.map((s) => (
                  <img 
                    class="sticker-item" 
                    src={s.image_url} 
                    onclick={`window.addCardSticker('${s.image_url}')`} 
                    ondragstart={`window.handleStickerDragStart(event, '${s.image_url}')`}
                    draggable="true"
                    alt={s.name} 
                    style="width: 50px; height: 50px; object-fit: contain; padding: 2px; background: #fff; border: 1px solid #e6dfd5; border-radius: 6px; cursor: pointer;"
                  />
                ))
              ) : (
                <p style="font-size: 0.85rem; color: var(--text-muted); margin: 8px 0;">No stickers uploaded yet. Add them in the Admin Portal.</p>
              )}
            </div>

            <!-- Sticker Size Control (disabled by default, opacity 0.35) -->
             <div id="stickerSizeControl" style="margin-top: 10px; opacity: 0.35; pointer-events: none; transition: opacity 0.2s ease;">
               <div class="builder-input-group" style="margin-bottom: 0;">
                 <label for="cardStickerSize" style="display: flex; justify-content: space-between; font-size: 0.78rem;">
                   <span>Sticker Size</span>
                   <span id="stickerSizeVal" style="font-weight: 600; color: var(--gold-dark);">70px</span>
                 </label>
                 <input type="range" id="cardStickerSize" min="30" max="150" value="70" style="width: 100%; cursor: pointer;" oninput="window.changeSelectedStickerSize(this.value)" disabled>
               </div>
             </div>
          </div>
        </div>

        <!-- Text Tab Content -->
        <div id="sidebarTabContentText" style="display: none;">
          <!-- 2. Text Input & Styling -->
          <div class="builder-section" style="margin-bottom: 0;">
            <h3>Add Custom Text</h3>
            <div class="builder-input-group">
              <label for="cardTextInput">Your Greeting Message</label>
              <textarea id="cardTextInput" placeholder="Type your message here..." oninput="window.addOrUpdateCardText()"></textarea>
            </div>

            <div class="text-style-row">
              <button id="cardTextBold" class="style-btn" onclick="window.toggleTextStyle('bold')"><b>B</b></button>
              <button id="cardTextItalic" class="style-btn" onclick="window.toggleTextStyle('italic')"><i>I</i></button>
            </div>

            <div class="color-font-row" style="display: flex; gap: 10px; margin-bottom: 10px; width: 100%;">
              <div class="builder-input-group" style="flex: 1; margin-bottom: 0;">
                <label for="cardTextColor">Color</label>
                <input type="color" id="cardTextColor" value="#5c5246" style="width: 100%; height: 38px; border: 1px solid #e6dfd5; border-radius: 6px; padding: 2px; cursor: pointer;" oninput="window.addOrUpdateCardText()">
              </div>
              <div class="builder-input-group" style="flex: 1; margin-bottom: 0;">
                <label for="cardFontFamily">Font</label>
                <select id="cardFontFamily" onchange="window.addOrUpdateCardText()" style="width: 100%; height: 38px; border: 1px solid #e6dfd5; border-radius: 6px; padding: 8px; background: #fff; font-family: inherit; font-size: 0.9rem;">
                  <option value="cormorant">Classic Serif</option>
                  <option value="jost">Modern Sans</option>
                </select>
              </div>
            </div>

            <div class="builder-input-group" style="margin-bottom: 12px; display: flex; flex-direction: column; gap: 4px; width: 100%;">
              <label for="cardFontSize" style="font-size: 0.78rem; font-weight: 500; color: var(--charcoal); text-transform: uppercase; letter-spacing: 0.05em;">Text Size</label>
              <input type="range" id="cardFontSize" min="16" max="120" value="40" style="width: 100%; cursor: pointer;" oninput="window.addOrUpdateCardText()">
            </div>

            <button class="builder-btn btn-solid" style="padding: 10px; width: 100%; margin-top: 10px;" onclick="window.addOrUpdateCardText()">Add / Update Text Box</button>
          </div>
        </div>

      <!-- Actions -->
      <div class="builder-actions-grid" style="margin-top: 10px; width: 100%; max-width: 100%;">
        <button class="builder-btn btn-outline btn-danger" onclick="window.deleteSelectedCardElement()">Delete Selected Item</button>
        <button class="builder-btn btn-outline" onclick="window.clearCardCanvas()">Reset Canvas</button>
        <button class="builder-btn btn-solid" style="background: var(--black); flex: 0 0 100%; width: 100%;" onclick="window.downloadCardImage()">Download Card (PNG)</button>
        <button class="builder-btn btn-solid" style="background: var(--gold-dark); color: white; flex: 0 0 100%; width: 100%;" onclick="if (typeof window.saveCardLayoutToSession === 'function') { window.saveCardLayoutToSession(); } window.closeGiftCardModal()">Save & Attach Card</button>
      </div>
    </div>

    <!-- Canvas Frame -->
    <div class="builder-canvas-area">
      <div class="canvas-frame">
        <canvas id="cardCanvas" width="900" height="1800" ondragover="window.handleCanvasDragOver(event)" ondrop="window.handleCanvasDrop(event)"></canvas>
      </div>
      <p class="canvas-hint" style="margin: 0; font-size: 0.78rem;">
        Click and drag stickers or text to position them on your card. Click an item to select it.
      </p>
    </div>
    </div>
  </div>
</div>

  <script is:inline>
    window.openGiftCardModal = function() {
      if (typeof window.setCartType === 'function') {
        window.setCartType('gift', false);
      }
      var modal = document.getElementById('giftCard');
      if (modal) {
        modal.classList.add('active');
        setTimeout(function() {
          if (typeof initCardBuilder === 'function') {
            initCardBuilder();
          }
        }, 50);
      }
    };
    window.closeGiftCardModal = function() {
      var modal = document.getElementById('giftCard');
      if (modal) {
        modal.classList.remove('active');
      }
    };
    window.switchSidebarTab = function(tab) {
      var designBtn = document.getElementById('tabBtnDesign');
      var textBtn = document.getElementById('tabBtnText');
      var designContent = document.getElementById('sidebarTabDesign');
      var textContent = document.getElementById('sidebarTabContentText');
      if (!designBtn || !textBtn || !designContent || !textContent) return;
      
      if (tab === 'design') {
        designBtn.style.borderBottomColor = 'var(--gold-dark)';
        designBtn.style.color = 'var(--gold-dark)';
        textBtn.style.borderBottomColor = 'transparent';
        textBtn.style.color = 'var(--stone)';
        
        designContent.style.display = 'block';
        textContent.style.display = 'none';
      } else {
        textBtn.style.borderBottomColor = 'var(--gold-dark)';
        textBtn.style.color = 'var(--gold-dark)';
        designBtn.style.borderBottomColor = 'transparent';
        designBtn.style.color = 'var(--stone)';
        
        textContent.style.display = 'block';
        designContent.style.display = 'none';
      }
    };

    // Canvas elements state
    var cardCanvas = null;
    var cardCtx = null;
    var cardBgImage = new Image();
    cardBgImage.crossOrigin = 'anonymous';
    var cardElements = [];
    var cardSelectedElement = null;
    var cardIsDragging = false;
    var cardDragStartX = 0;
    var cardDragStartY = 0;
    var cardActiveTemplate = (window.__INITIAL_CATALOG__ && window.__INITIAL_CATALOG__.cardTemplates && window.__INITIAL_CATALOG__.cardTemplates.length > 0)
      ? window.__INITIAL_CATALOG__.cardTemplates[0].image_url
      : '';

    // Fonts
    var cardFonts = {
      'cormorant': "'Cormorant Garamond', serif",
      'jost': "'Jost', sans-serif"
    };

    window.saveCardLayoutToSession = function() {
      var elementsRecipe = cardElements.map(function(el) {
        var recipeEl = {
          type: el.type,
          content: el.content,
          x: el.x,
          y: el.y,
          size: el.size
        };
        if (el.type === 'text') {
          recipeEl.color = el.color;
          recipeEl.fontFamily = el.fontFamily;
          recipeEl.isBold = el.isBold;
          recipeEl.isItalic = el.isItalic;
          recipeEl.align = el.align;
          recipeEl.maxWidth = el.maxWidth;
        }
        return recipeEl;
      });
      
      var currentLayoutStr = sessionStorage.getItem('lumiere_gift_card_layout');
      var layoutId = null;
      if (currentLayoutStr) {
        try {
          var parsed = JSON.parse(currentLayoutStr);
          layoutId = parsed.id;
        } catch (e) {}
      }
      if (!layoutId) {
        layoutId = 'layout_' + Date.now().toString(36) + '_' + Math.random().toString(36).substring(2, 9);
      }
      
      var layoutPayload = {
        id: layoutId,
        templatePath: cardActiveTemplate,
        elements: elementsRecipe
      };
      
      sessionStorage.setItem('lumiere_gift_card_layout', JSON.stringify(layoutPayload));
    }

    function checkOfflineStatusAndBlock() {
      if (!navigator.onLine) {
        var overlay = document.getElementById('offlineOverlay');
        if (overlay) {
          overlay.classList.add('active');
        }
        if (window.showToast) {
          window.showToast("You are offline. Please reconnect to customize your card.", true);
        }
        return true;
      }
      return false;
    }

    function initCardBuilder() {
      cardCanvas = document.getElementById('cardCanvas');
      if (!cardCanvas) return;
      cardCtx = cardCanvas.getContext('2d');
      cardCtx.setTransform(1, 0, 0, 1, 0, 0);
      cardCtx.scale(3, 3);

      // Register interaction listeners
      cardCanvas.removeEventListener('mousedown', onCardMouseDown);
      cardCanvas.removeEventListener('mousemove', onCardMouseMove);
      cardCanvas.removeEventListener('mouseup', onCardMouseUp);
      cardCanvas.removeEventListener('mouseleave', onCardMouseUp);
      cardCanvas.addEventListener('mousedown', onCardMouseDown);
      cardCanvas.addEventListener('mousemove', onCardMouseMove);
      cardCanvas.addEventListener('mouseup', onCardMouseUp);
      cardCanvas.addEventListener('mouseleave', onCardMouseUp);

      cardCanvas.removeEventListener('touchstart', onCardTouchStart);
      cardCanvas.removeEventListener('touchmove', onCardTouchMove);
      cardCanvas.removeEventListener('touchend', onCardTouchEnd);
      cardCanvas.addEventListener('touchstart', onCardTouchStart, { passive: false });
      cardCanvas.addEventListener('touchmove', onCardTouchMove, { passive: false });
      cardCanvas.addEventListener('touchend', onCardTouchEnd, { passive: false });

      // Restore layout from sessionStorage if any
      var savedLayoutStr = sessionStorage.getItem('lumiere_gift_card_layout');
      if (savedLayoutStr) {
        try {
          var saved = JSON.parse(savedLayoutStr);
          if (saved && saved.templatePath) {
            cardActiveTemplate = saved.templatePath;
            
            // Set thumbnail active class
            var thumbs = document.querySelectorAll('.template-thumb');
            thumbs.forEach(t => {
              if (t.getAttribute('src') === cardActiveTemplate) {
                t.classList.add('active');
              } else {
                t.classList.remove('active');
              }
            });
          }
          if (saved && Array.isArray(saved.elements)) {
            cardElements = saved.elements.map(function(el) {
              if (el.type === 'sticker') {
                var img = new Image();
                img.crossOrigin = 'anonymous';
                img.src = el.content;
                img.onload = function() { drawCardCanvas(); };
                el.imgObj = img;
              }
              return el;
            });
          }
        } catch (e) {
          console.error("Failed to parse saved layout from sessionStorage:", e);
        }
      }

      // Handle template changes
      cardBgImage.onload = function() {
        drawCardCanvas();
      };
      cardBgImage.src = cardActiveTemplate;

      // Set initial text controls values
      var colorPicker = document.getElementById('cardTextColor');
      if (colorPicker) colorPicker.value = '#5c5246';
      
      drawCardCanvas();
    }

    // Draw loop
    function drawCardCanvas() {
      if (!cardCtx || !cardCanvas) return;
      cardCtx.clearRect(0, 0, 300, 600);

      // 1. Draw template image background
      if (cardBgImage.complete && cardBgImage.naturalWidth > 0) {
        cardCtx.drawImage(cardBgImage, 0, 0, 300, 600);
      } else {
        cardCtx.fillStyle = '#faf7f2';
        cardCtx.fillRect(0, 0, 300, 600);
      }

      // 2. Draw all elements
      for (var i = 0; i < cardElements.length; i++) {
        var el = cardElements[i];
        if (el.type === 'sticker') {
          if (!el.imgObj) {
            el.imgObj = new Image();
            el.imgObj.crossOrigin = 'anonymous';
            el.imgObj.src = el.content;
            el.imgObj.onload = function() {
              drawCardCanvas();
            };
          }
          if (el.imgObj.complete && el.imgObj.naturalWidth > 0) {
            var size = el.size || 70;
            cardCtx.drawImage(el.imgObj, el.x - size/2, el.y - size/2, size, size);
          } else {
            cardCtx.strokeStyle = '#e6dfd5';
            cardCtx.lineWidth = 1;
            cardCtx.strokeRect(el.x - 35, el.y - 35, 70, 70);
          }
        } else if (el.type === 'text') {
          var fontStr = (el.isItalic ? 'italic ' : '') + (el.isBold ? 'bold ' : '') + el.size + "px " + cardFonts[el.fontFamily || 'cormorant'];
          cardCtx.font = fontStr;
          cardCtx.fillStyle = el.color || '#5c5246';
          cardCtx.textAlign = el.align || 'center';
          cardCtx.textBaseline = 'top';

          var lines = wrapCardText(cardCtx, el.content, el.maxWidth || 260);
          var currentY = el.y;
          for (var j = 0; j < lines.length; j++) {
            cardCtx.fillText(lines[j], el.x, currentY);
            currentY += el.size * 1.25;
          }
        }

        // Draw bounding box if selected
        if (el === cardSelectedElement) {
          cardCtx.strokeStyle = '#c5a880';
          cardCtx.lineWidth = 1.5;
          cardCtx.setLineDash([4, 4]);
          
          var boxWidth = el.width + 12;
          var boxHeight = el.height + 12;
          cardCtx.strokeRect(el.x - boxWidth/2, el.y - (el.type === 'sticker' ? boxHeight/2 : 0) - 6, boxWidth, boxHeight);
          cardCtx.setLineDash([]);
        }
      }
    }

    // wrapText helper
    function wrapCardText(context, text, maxWidth) {
      if (!text) return [];
      var words = text.split(/\s+/);
      var lines = [];
      var currentLine = '';

      for (var n = 0; n < words.length; n++) {
        var testLine = currentLine + words[n] + ' ';
        var metrics = context.measureText(testLine);
        var testWidth = metrics.width;
        if (testWidth > maxWidth && n > 0) {
          lines.push(currentLine.trim());
          currentLine = words[n] + ' ';
        } else {
          currentLine = testLine;
        }
      }
      lines.push(currentLine.trim());
      return lines;
    }

    // Calculate bounding box for hit-testing
    function measureElement(el) {
      if (!cardCtx) return;
      if (el.type === 'sticker') {
        el.width = el.size;
        el.height = el.size;
      } else if (el.type === 'text') {
        var fontStr = (el.isItalic ? 'italic ' : '') + (el.isBold ? 'bold ' : '') + el.size + "px " + cardFonts[el.fontFamily || 'cormorant'];
        cardCtx.font = fontStr;
        var lines = wrapCardText(cardCtx, el.content, el.maxWidth || 260);
        el.height = lines.length * (el.size * 1.25);
        
        var maxW = 0;
        for (var i = 0; i < lines.length; i++) {
          var w = cardCtx.measureText(lines[i]).width;
          if (w > maxW) maxW = w;
        }
        el.width = Math.max(maxW, 40);
      }
    }

    // Hit-testing
    function getElementAt(x, y) {
      for (var i = cardElements.length - 1; i >= 0; i--) {
        var el = cardElements[i];
        measureElement(el);
        if (el.type === 'sticker') {
          var radius = el.size / 2;
          if (x >= el.x - radius - 6 && x <= el.x + radius + 6 && y >= el.y - radius - 6 && y <= el.y + radius + 6) {
            return el;
          }
        } else if (el.type === 'text') {
          var minX = el.x - el.width / 2 - 6;
          var maxX = el.x + el.width / 2 + 6;
          var minY = el.y - 6;
          var maxY = el.y + el.height + 6;
          if (x >= minX && x <= maxX && y >= minY && y <= maxY) {
            return el;
          }
        }
      }
      return null;
    }

    // Interaction Handlers
    function onCardMouseDown(e) {
      if (checkOfflineStatusAndBlock()) return;
      var rect = cardCanvas.getBoundingClientRect();
      var scaleX = 300 / rect.width;
      var scaleY = 600 / rect.height;
      var x = (e.clientX - rect.left) * scaleX;
      var y = (e.clientY - rect.top) * scaleY;

      var clicked = getElementAt(x, y);
      if (clicked) {
        cardSelectedElement = clicked;
        cardIsDragging = true;
        cardDragStartX = x - clicked.x;
        cardDragStartY = y - clicked.y;
        
        // Update sidebar UI with values of selected element
        if (clicked.type === 'text') {
          document.getElementById('cardTextInput').value = clicked.content;
          document.getElementById('cardTextColor').value = clicked.color || '#5c5246';
          document.getElementById('cardFontSize').value = clicked.size;
          document.getElementById('cardFontFamily').value = clicked.fontFamily || 'cormorant';
          document.getElementById('cardTextBold').classList.toggle('active', !!clicked.isBold);
          document.getElementById('cardTextItalic').classList.toggle('active', !!clicked.isItalic);
        }
      } else {
        cardSelectedElement = null;
      }
      drawCardCanvas();
      if (typeof window.updateSelectionUI === 'function') {
        window.updateSelectionUI();
      }
    }

    function onCardMouseMove(e) {
      if (!cardIsDragging || !cardSelectedElement) return;
      var rect = cardCanvas.getBoundingClientRect();
      var scaleX = 300 / rect.width;
      var scaleY = 600 / rect.height;
      var x = (e.clientX - rect.left) * scaleX;
      var y = (e.clientY - rect.top) * scaleY;

      cardSelectedElement.x = x - cardDragStartX;
      cardSelectedElement.y = y - cardDragStartY;
      
      // Bounds clamping
      cardSelectedElement.x = Math.max(10, Math.min(290, cardSelectedElement.x));
      cardSelectedElement.y = Math.max(10, Math.min(590, cardSelectedElement.y));

      drawCardCanvas();
    }

    function onCardMouseUp() {
      cardIsDragging = false;
      saveCardLayoutToSession();
    }

    // Touch handlers
    function onCardTouchStart(e) {
      if (checkOfflineStatusAndBlock()) return;
      if (e.touches.length === 0) return;
      var touch = e.touches[0];
      var rect = cardCanvas.getBoundingClientRect();
      var scaleX = 300 / rect.width;
      var scaleY = 600 / rect.height;
      var x = (touch.clientX - rect.left) * scaleX;
      var y = (touch.clientY - rect.top) * scaleY;

      var clicked = getElementAt(x, y);
      if (clicked) {
        e.preventDefault(); // Prevent scrolling when dragging elements
        cardSelectedElement = clicked;
        cardIsDragging = true;
        cardDragStartX = x - clicked.x;
        cardDragStartY = y - clicked.y;
      } else {
        cardSelectedElement = null;
      }
      drawCardCanvas();
      if (typeof window.updateSelectionUI === 'function') {
        window.updateSelectionUI();
      }
    }

    function onCardTouchMove(e) {
      if (!cardIsDragging || !cardSelectedElement || e.touches.length === 0) return;
      e.preventDefault();
      var touch = e.touches[0];
      var rect = cardCanvas.getBoundingClientRect();
      var scaleX = 300 / rect.width;
      var scaleY = 600 / rect.height;
      var x = (touch.clientX - rect.left) * scaleX;
      var y = (touch.clientY - rect.top) * scaleY;

      cardSelectedElement.x = x - cardDragStartX;
      cardSelectedElement.y = y - cardDragStartY;

      cardSelectedElement.x = Math.max(10, Math.min(290, cardSelectedElement.x));
      cardSelectedElement.y = Math.max(10, Math.min(590, cardSelectedElement.y));

      drawCardCanvas();
    }

    function onCardTouchEnd() {
      cardIsDragging = false;
      saveCardLayoutToSession();
    }

    // External Action APIs
    window.updateSelectionUI = function() {
      var stickerControl = document.getElementById('stickerSizeControl');
      if (!stickerControl) return;
      var sizeInput = document.getElementById('cardStickerSize');
      var sizeValSpan = document.getElementById('stickerSizeVal');
      
      if (cardSelectedElement && cardSelectedElement.type === 'sticker') {
        stickerControl.style.opacity = '1';
        stickerControl.style.pointerEvents = 'auto';
        if (sizeInput) {
          sizeInput.disabled = false;
          sizeInput.value = cardSelectedElement.size || 70;
        }
        if (sizeValSpan) sizeValSpan.textContent = (cardSelectedElement.size || 70) + 'px';
      } else {
        stickerControl.style.opacity = '0.35';
        stickerControl.style.pointerEvents = 'none';
        if (sizeInput) {
          sizeInput.disabled = true;
          sizeInput.value = 70;
        }
        if (sizeValSpan) sizeValSpan.textContent = '70px';
      }
    };

    window.changeSelectedStickerSize = function(val) {
      var size = parseInt(val, 10) || 70;
      var sizeValSpan = document.getElementById('stickerSizeVal');
      if (sizeValSpan) sizeValSpan.textContent = size + 'px';
      
      if (cardSelectedElement && cardSelectedElement.type === 'sticker') {
        cardSelectedElement.size = size;
        cardSelectedElement.width = size;
        cardSelectedElement.height = size;
        drawCardCanvas();
        saveCardLayoutToSession();
      }
    };

    window.changeCardTemplate = function(templatePath, thumbEl) {
      if (checkOfflineStatusAndBlock()) return;
      cardActiveTemplate = templatePath;
      cardBgImage.src = templatePath;
      
      // Manage active classes
      var thumbs = document.querySelectorAll('.template-thumb');
      thumbs.forEach(t => t.classList.remove('active'));
      if (thumbEl) thumbEl.classList.add('active');
      saveCardLayoutToSession();
    };

    window.handleStickerDragStart = function(event, stickerPath) {
      if (event && event.dataTransfer) {
        event.dataTransfer.setData('text/plain', stickerPath);
        event.dataTransfer.effectAllowed = 'copy';
      }
    };

    window.handleCanvasDragOver = function(event) {
      if (event) {
        event.preventDefault();
        if (event.dataTransfer) {
          event.dataTransfer.dropEffect = 'copy';
        }
      }
    };

    window.handleCanvasDrop = function(event) {
      if (event) {
        event.preventDefault();
        var stickerPath = '';
        if (event.dataTransfer) {
          stickerPath = event.dataTransfer.getData('text/plain');
        }
        if (!stickerPath) return;

        var canvas = document.getElementById('cardCanvas');
        if (!canvas) return;

        var rect = canvas.getBoundingClientRect();
        var clientX = event.clientX - rect.left;
        var clientY = event.clientY - rect.top;

        var canvasX = (clientX / rect.width) * 300;
        var canvasY = (clientY / rect.height) * 600;

        window.addCardStickerAt(stickerPath, canvasX, canvasY);
      }
    };

    window.addCardStickerAt = function(stickerPath, x, y) {
      if (checkOfflineStatusAndBlock()) return;
      var img = new Image();
      img.crossOrigin = 'anonymous';
      img.src = stickerPath;
      
      var newSticker = {
        type: 'sticker',
        content: stickerPath,
        imgObj: img,
        x: x,
        y: y,
        size: 70,
        width: 70,
        height: 70
      };
      
      img.onload = function() {
        drawCardCanvas();
      };
      
      cardElements.push(newSticker);
      cardSelectedElement = newSticker;
      drawCardCanvas();
      saveCardLayoutToSession();
      if (typeof window.updateSelectionUI === 'function') {
        window.updateSelectionUI();
      }
    };

    window.addCardSticker = function(stickerPath) {
      // Add in the center of the canvas by default if clicked
      window.addCardStickerAt(stickerPath, 150, 300);
    };

    window.addOrUpdateCardText = function() {
      if (checkOfflineStatusAndBlock()) return;
      var textInput = document.getElementById('cardTextInput');
      var textVal = textInput ? textInput.value.trim() : '';
      if (!textVal) return;

      var colorVal = document.getElementById('cardTextColor').value;
      var sizeVal = parseInt(document.getElementById('cardFontSize').value, 10) || 18;
      var familyVal = document.getElementById('cardFontFamily').value;
      var isBold = document.getElementById('cardTextBold').classList.contains('active');
      var isItalic = document.getElementById('cardTextItalic').classList.contains('active');

      if (cardSelectedElement && cardSelectedElement.type === 'text') {
        // Update active text
        cardSelectedElement.content = textVal;
        cardSelectedElement.color = colorVal;
        cardSelectedElement.size = sizeVal;
        cardSelectedElement.fontFamily = familyVal;
        cardSelectedElement.isBold = isBold;
        cardSelectedElement.isItalic = isItalic;
        measureElement(cardSelectedElement);
      } else {
        // Create new text
        var newText = {
          type: 'text',
          content: textVal,
          x: 150,
          y: 200,
          color: colorVal,
          size: sizeVal,
          fontFamily: familyVal,
          isBold: isBold,
          isItalic: isItalic,
          maxWidth: 260
        };
        measureElement(newText);
        cardElements.push(newText);
        cardSelectedElement = newText;
      }
      
      drawCardCanvas();
      saveCardLayoutToSession();
    };

    window.toggleTextStyle = function(styleType) {
      if (checkOfflineStatusAndBlock()) return;
      var btn = document.getElementById('cardText' + styleType.charAt(0).toUpperCase() + styleType.slice(1));
      if (btn) btn.classList.toggle('active');
      
      // If text element is active, apply instantly
      if (cardSelectedElement && cardSelectedElement.type === 'text') {
        if (styleType === 'bold') cardSelectedElement.isBold = btn.classList.contains('active');
        if (styleType === 'italic') cardSelectedElement.isItalic = btn.classList.contains('active');
        measureElement(cardSelectedElement);
        drawCardCanvas();
        saveCardLayoutToSession();
      }
    };

    window.deleteSelectedCardElement = function() {
      if (checkOfflineStatusAndBlock()) return;
      if (!cardSelectedElement) return;
      var idx = cardElements.indexOf(cardSelectedElement);
      if (idx !== -1) {
        cardElements.splice(idx, 1);
        cardSelectedElement = null;
        drawCardCanvas();
        saveCardLayoutToSession();
        if (typeof window.updateSelectionUI === 'function') {
          window.updateSelectionUI();
        }
      }
    };

    window.clearCardCanvas = function() {
      if (checkOfflineStatusAndBlock()) return;
      if (typeof window.showConfirmModal === 'function') {
        window.showConfirmModal({
          category: 'Card Designer',
          title: 'Clear Canvas?',
          text: 'Are you sure you want to clear your designs?',
          confirmText: 'Clear',
          onConfirm: () => {
            cardElements = [];
            cardSelectedElement = null;
            drawCardCanvas();
            saveCardLayoutToSession();
            if (typeof window.updateSelectionUI === 'function') {
              window.updateSelectionUI();
            }
          }
        });
      } else {
        if (confirm("Are you sure you want to clear your designs?")) {
          cardElements = [];
          cardSelectedElement = null;
          drawCardCanvas();
          saveCardLayoutToSession();
          if (typeof window.updateSelectionUI === 'function') {
            window.updateSelectionUI();
          }
        }
      }
    };

    window.downloadCardImage = function() {
      // Clear selection border first
      var prevSelection = cardSelectedElement;
      cardSelectedElement = null;
      drawCardCanvas();

      setTimeout(function() {
        try {
          var dataUrl = cardCanvas.toDataURL('image/png');
          var link = document.createElement('a');
          link.download = 'cozy-aura-greeting-card.png';
          link.href = dataUrl;
          document.body.appendChild(link);
          link.click();
          document.body.removeChild(link);
        } catch (err) {
          alert("Unable to download image: " + err.message);
        }
        
        // Restore selection
        cardSelectedElement = prevSelection;
        drawCardCanvas();
      }, 100);
    };


  </script>

