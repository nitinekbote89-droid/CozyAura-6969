---
import Layout from '../layouts/Layout.astro';
import Modals from '../components/Modals.astro';

// SSR initial catalog data to avoid client-side API round-trip
let initialCatalog = null;
let heroImageUrl = null;
try {
  const apiUrl = new URL('/api/store', Astro.request.url);
  apiUrl.searchParams.set('siteToken', 'LUMIERE_STORE_2026');
  apiUrl.searchParams.set('t', Date.now().toString());
  const res = await fetch(apiUrl);
  if (res.ok) {
    const json = await res.json();
    if (json.success) {
      initialCatalog = json.data;
      const sf = json.data.storefrontImages;
      if (sf?.home_hero) {
        let url = sf.home_hero;
        if (url.includes('/image/upload/f_auto')) {
          url = url.replace(/\/w_\d+/, '/w_1200');
        } else if (url.includes('/image/upload/')) {
          url = url.replace('/image/upload/', '/image/upload/f_auto,q_auto,w_1200/');
        }
        heroImageUrl = url;
      }
    }
  }
} catch (e) {
  console.warn('SSR catalog fetch failed, will load client-side');
}

// SSR products grid HTML to eliminate CLS from JS-populated product cards
function ssrOptimizeUrl(url, width) {
  if (!url || !url.includes('/image/upload/')) return url;
  if (url.includes('/image/upload/f_auto')) {
    return url.replace(/\/w_\d+/, `/w_${width}`);
  }
  return url.replace('/image/upload/', `/image/upload/f_auto,q_auto,w_${width}/`);
}
function ssrSrcset(url) {
  if (!url || !url.includes('/image/upload/')) return '';
  const uploadIdx = url.indexOf('/image/upload/');
  const prefix = url.substring(0, uploadIdx + 14);
  let rest = url.substring(uploadIdx + 14);
  const slashIdx = rest.indexOf('/');
  if (slashIdx !== -1) {
    let transform = rest.substring(0, slashIdx);
    const publicId = rest.substring(slashIdx);
    if (transform.includes('f_auto')) {
      transform = transform.replace(/w_\d+/, 'w_');
    } else {
      transform = 'f_auto,q_auto,w_';
    }
    const widths = [400, 800, 1200];
    return widths.map(w => `${prefix}${transform.replace(/w_$/, `w_${w}`)}${publicId} ${w}w`).join(', ');
  }
  return '';
}
let heroSrcset = heroImageUrl ? ssrSrcset(heroImageUrl) : '';
let productsGridHtml = '';
if (initialCatalog?.inventory) {
  const cards = initialCatalog.inventory.map(item => {
    let displayCategory = item.category || '';
    if (displayCategory.toLowerCase().trim() === 'jar2') {
      displayCategory = 'jar';
    }
    const imgHtml = item.coverImage
      ? `<img src="${ssrOptimizeUrl(item.coverImage, 300)}" alt="${item.name}" width="300" height="400" style="width:100%;height:100%;object-fit:cover;">`
      : '<div class="cream-fallback"><span class="material-symbols-outlined" style="font-size:2rem;color:var(--taupe);">local_fire_department</span></div>';
    return `<div class="product-card" onclick="window.openProductModal('${item.id}')">
      <div class="product-img">
        ${!item.stock || item.stock < 1 ? '<span class="badge-out">Out of Stock</span>' : ''}
        ${imgHtml}
      </div>
      <h3>${item.name}</h3><div class="scent">${displayCategory}</div><div class="price">₹${item.price}</div>
    </div>`;
  });
  productsGridHtml = cards.join('');
}

// SSR page state — only show the correct section to eliminate CLS from section transitions
const initialPage = Astro.url.searchParams.get('page') || 'home';
const pages_list = ['home', 'shop', 'cartPage', 'payment', 'about', 'contact', 'ordersPage', 'addressesPage'];

const igPosts = Array.from({ length: 12 }, (_, i) => ({
  id: i + 1,
  gradient: [
    'linear-gradient(135deg,#EDE5D8,#D4C4B0)',
    'linear-gradient(135deg,#E8DDD0,#C4B5A0)',
    'linear-gradient(135deg,#F5EDE0,#E0D4C3)',
    'linear-gradient(135deg,#EDE5D8,#C4B5A0)',
    'linear-gradient(135deg,#F7F0E6,#D4C4B0)',
    'linear-gradient(135deg,#E8DDD0,#EDE0D0)'
  ][i % 6]
}));
---

<Layout>
  {heroImageUrl && <link rel="preload" as="image" href={heroImageUrl} fetchpriority="high" slot="head" />}
  <div class="page-wrapper">
  <nav>
    <a href="#" class="nav-logo" onclick="event.preventDefault(); window.showPage('home')">Lumi<span>ère</span></a>
    <ul class="nav-links">
      <li><a href="#" onclick="event.preventDefault(); window.showPage('home')">Home</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('shop')">Shop</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('about')">About</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('contact')">Contact</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('ordersPage')">Your Orders</a></li>
    </ul>
    <div class="nav-right">
      <div class="nav-account-wrap">
        <button class="nav-account-btn" onclick="window.toggleAccountMenu()" id="navAccountBtn" title="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></button>
        <div class="account-dropdown" id="accountDropdown">
          <div class="account-dropdown-header" id="dropdownUserInfo">Guest</div>
          <a href="#" onclick="event.preventDefault(); window.showPage('ordersPage'); window.closeAccountMenu()">Your Orders</a>
          <a href="#" onclick="event.preventDefault(); window.showPage('addressesPage'); window.closeAccountMenu()">Saved Address</a>
          <a href="#" onclick="event.preventDefault(); window.showPage('contact'); window.closeAccountMenu()">Help & Support</a>
          <a href="#" onclick="event.preventDefault(); window.handleAccountDropdownAction();" id="dropdownLogout">Log Out</a>
        </div>
      </div>
      <button class="nav-cta" onclick="window.showPage('cartPage')">Checkout (0)</button>
    </div>
  </nav>

  <main>
  <section id="home" class={initialPage === 'home' ? 'active' : ''}>
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
    <div class="glow-orb orb-3"></div>
    <div class="hero-inner" style={heroImageUrl ? '' : 'grid-template-columns: 1fr;'}>
      <div class="hero-text">
        <span class="hero-subtitle">Meticulously Hand-Poured Soya Candles</span>
        <h1>Where<br><em>stillness</em><br>finds its flame.</h1>
        <p>Hand-poured 100% natural soya candles, crafted in small batches with botanically sourced fragrances. Clean, conscious, timeless.</p>
        <div class="hero-btns">
          <button class="btn-primary" onclick="window.showPage('shop')">Explore the Collection</button>
        </div>
      </div>
      <div class="hero-visual" style={heroImageUrl ? '' : 'display: none;'}>
        <div class="hero-float-wrapper">
          <div class="hero-image-frame">
            <img src={heroImageUrl || "data:image/svg+xml;utf8,&lt;svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1 1'&gt;&lt;/svg&gt;"} srcset={heroSrcset} sizes="(max-width: 480px) 90vw, (max-width: 768px) 50vw, 380px" id="storefrontHeroImg" alt="Lumière Luxury Soya Candle" class="hero-img-element" width="380" height="480" fetchpriority="high" loading="eager" style={heroImageUrl ? 'opacity:1' : 'opacity:0;transition:opacity 0.4s ease'} />
            <div class="hero-frame-glow"></div>
            <div class="hero-frame-border"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="home-section bestseller-sticky-section">
      <div class="bestseller-left">
        <div class="bestseller-sticky-header">
          <span class="bestseller-subtitle">Curated Favorites</span>
          <h2>Our<br><em>Bestsellers</em></h2>
          <p>Discover our most loved hand-poured creations, ranked by our community. Each blend is meticulously crafted to bring stillness and warmth to your space.</p>
          <button class="btn-primary" onclick="window.showPage('shop')">View All Collection</button>
        </div>
      </div>
      <div class="bestseller-right" id="bestsellerStickyContainer">
        <p style="text-align:center;color:var(--stone);padding-top:4rem;">Loading...</p>
      </div>
    </div>

    <div class="home-section home-values">
      <div class="section-header" style="text-align:center;justify-content:center;">
        <h2>Why <em>Lumiere</em></h2>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
          <h3>100% Natural Wax</h3>
          <p>Pure soya wax grown without pesticides, bleaching agents, or GMOs. Clean-burning from first light to last.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3>Hand-Poured in India</h3>
          <p>Every candle is poured by hand in small batches in our Koregaon Park studio. Never mass-produced — always intentional.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg></div>
