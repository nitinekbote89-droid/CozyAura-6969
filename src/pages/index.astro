        padding: 1.5rem 2.5rem;
        display: flex;
        flex-direction: column;
      }
      .modal-overlay.active .gift-card-modal {
        transform: translateY(0);
      }
      .card-builder-container {
        display: flex;
        flex-wrap: wrap;
        gap: 25px;
        margin: 0.5rem auto;
        max-width: 1040px;
        justify-content: center;
        align-items: stretch;
        font-family: 'Jost', sans-serif;
        flex: 1;
        min-height: 0;
        /* width: 100%; */
      }
      .builder-sidebar {
        flex: 1;
        min-width: 400px;
        background: #faf7f2;
        border: 1px solid #e6dfd5;
        border-radius: 8px;
        padding: 16px;
        box-shadow: 0 4px 20px #00000005;
        display: flex;
        flex-direction: column;
        height: 100%;
        overflow-y: auto;
        scrollbar-width: thin;
      }
      .builder-section {
        margin-bottom: 12px;
      }
      .builder-section h3 {
        font-family: 'Cormorant Garamond', serif;
        font-size: 1.05rem;
        color: var(--black);
        margin-bottom: 8px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom: 1px solid #e6dfd5;
        padding-bottom: 4px;
      }
      .template-grid {
        display: flex;
        gap: 10px;
        overflow-x: auto;
        padding: 4px 0;
        scrollbar-width: thin;
      }
      .template-thumb {
        width: 40px;
        height: 80px;
        border-radius: 6px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s ease;
        object-fit: cover;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
      }
      .template-thumb:hover, .template-thumb.active {
        border-color: var(--gold-dark);
        transform: translateY(-2px);
      }
      .sticker-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .sticker-item {
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #ffffff;
        border: 1px solid #e6dfd5;
        border-radius: 8px;
        font-size: 1.5rem;
        cursor: pointer;
        transition: all 0.15s ease;
        user-select: none;
      }
      .sticker-item:hover {
        background: #fbf9f6;
        border-color: var(--gold-dark);
        transform: scale(1.1);
      }
      .builder-input-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 8px;
      }
      .builder-input-group label {
        font-size: 0.78rem;
        font-weight: 500;
        color: var(--charcoal);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }
      .builder-input-group textarea, .builder-input-group select {
        padding: 8px;
        border: 1px solid #e6dfd5;
        border-radius: 6px;
        background: #fff;
        font-family: inherit;
        font-size: 0.9rem;
      }
      .builder-input-group textarea {
        resize: vertical;
        min-height: 52px;
      }
      .text-style-row {
        display: flex;
        gap: 6px;
        margin-bottom: 8px;
      }
      .style-btn {
        flex: 1;
        padding: 6px;
        background: #fff;
        border: 1px solid #e6dfd5;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 500;
        transition: all 0.2s;
      }
      .style-btn.active {
        background: var(--black);
        color: #fff;
        border-color: var(--black);
      }
      .color-size-row {
        display: flex;
        gap: 10px;
        align-items: center;
        margin-bottom: 10px;
      }
      .color-size-row .builder-input-group {
        margin-bottom: 0;
        flex: 1;
      }
      .builder-canvas-area {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 12px;
        flex: 1.8;
        min-width: 320px;
      }
      @media (min-width: 768px) {
        .builder-canvas-area {
          border-left: 1px solid rgba(196,181,160,0.25);
          padding-left: 25px;
        }
      }
      .canvas-frame {
        background: #f0ede6;
        padding: 10px;
        border-radius: 12px;
        box-shadow: inset 0 2px 8px rgba(0,0,0,0.03), 0 15px 40px rgba(0,0,0,0.06);
        position: relative;
      }
      canvas#cardCanvas {
        background: #fff;
        border-radius: 6px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        cursor: crosshair;
        touch-action: none;
        max-width: 100%;
        max-height: 560px;
        aspect-ratio: 1 / 2;
        height: auto;
      }
      .canvas-hint {
        font-size: 0.85rem;
        color: #8c8275;
        font-style: italic;
        text-align: center;
        max-width: 360px;
      }
      .builder-actions-grid {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: auto;
        width: 100%;
        max-width: 100%;
        justify-content: center;
      }
      .builder-btn {
        flex: 1;
        min-width: 120px;
        padding: 8px 10px;
        border-radius: 6px;
        font-weight: 500;
        text-align: center;
