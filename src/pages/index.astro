---
import Layout from '../layouts/Layout.astro';
import Modals from '../components/Modals.astro';
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.SUPABASE_URL,
  import.meta.env.SUPABASE_SERVICE_ROLE_KEY
);

let ssrCatalogCache = null;
let ssrCatalogCacheTime = 0;
let ssrCacheRefreshing = false;
const SSR_CACHE_FRESH_TTL = 600_000;
const SSR_CACHE_STALE_TTL = 86_400_000;

async function fetchCatalogData() {
  const [{ data: setRow }, { data: sfRow }, { data: dbCoupons }] = await Promise.all([
    supabase.from('settings').select('value').eq('key', 'GLOBAL_FRAGRANCES').single(),
    supabase.from('settings').select('value').eq('key', 'STOREFRONT_IMAGES').single(),
    supabase.from('coupons').select('*').eq('status', 'Active')
  ]);

  let dbProducts = [], dbVariants = [];
  let hasSalesView = false;
  try {
    const { data, error } = await supabase.from('products_with_sales').select('*').order('created_at', { ascending: false });
    if (data && !error) { dbProducts = data; hasSalesView = true; }
  } catch (e) {}
  if (!hasSalesView) {
    const { data } = await supabase.from('products').select('*').order('created_at', { ascending: false });
    dbProducts = data || [];
  }
  try {
    const { data } = await supabase.from('product_variants').select('*');
    dbVariants = data || [];
  } catch (e) {}

  const storefrontImages = sfRow?.value || null;
  let heroImageUrl = null;
  if (storefrontImages?.home_hero) {
    heroImageUrl = storefrontImages.home_hero;
  }

  const variantsByProductId = {};
  dbVariants.forEach(v => {
    if (!variantsByProductId[v.product_id]) variantsByProductId[v.product_id] = [];
    variantsByProductId[v.product_id].push(v);
  });

  const inventory = dbProducts.map(p => {
    const pVars = variantsByProductId[p.id] || [];
    let fragranceStocks = {}, fragranceImages = {};
    pVars.forEach(v => {
      fragranceStocks[v.variant_name] = v.stock;
      if (v.image_url) fragranceImages[v.variant_name] = v.image_url;
    });
    return {
      id: p.id, name: p.name, category: p.category, price: p.price,
      weight: p.weight, stock: p.stock, coverImage: p.cover_image,
      description: p.description, specifications: p.specifications,
      fragranceStocks, fragranceImages,
      totalSales: hasSalesView ? (p.total_sales || 0) : 0,
      salesRank: hasSalesView ? (p.sales_rank || null) : null
    };
  });

  const initialCatalog = { inventory, fragrances: setRow?.value || [], coupons: dbCoupons || [], storefrontImages };
  return { initialCatalog, heroImageUrl };
}

// Stale-while-revalidate: serve cached instantly, refresh in background if stale
let initialCatalog = null;
let heroImageUrl = null;
const now = Date.now();

if (ssrCatalogCache && (now - ssrCatalogCacheTime) < SSR_CACHE_STALE_TTL) {
  const cached = ssrCatalogCache;
  initialCatalog = cached.initialCatalog;
  heroImageUrl = cached.heroImageUrl;
  if ((now - ssrCatalogCacheTime) > SSR_CACHE_FRESH_TTL && !ssrCacheRefreshing) {
    ssrCacheRefreshing = true;
    fetchCatalogData().then(result => {
      ssrCatalogCache = result;
      ssrCatalogCacheTime = Date.now();
      ssrCacheRefreshing = false;
    }).catch(() => {
      ssrCacheRefreshing = false;
    });
  }
} else try {
  const result = await fetchCatalogData();
  initialCatalog = result.initialCatalog;
  heroImageUrl = result.heroImageUrl;
  ssrCatalogCache = result;
  ssrCatalogCacheTime = Date.now();
} catch (e) {
  console.warn('SSR catalog query failed, will load client-side');
}

// Cloudinary auto-optimization: serve WebP + auto quality
function cloudinaryOpt(url) {
  return url;
}

// SSR products grid HTML to eliminate CLS from JS-populated product cards
let productsGridHtml = '';
if (initialCatalog?.inventory) {
  const cards = initialCatalog.inventory.map(item => {
    let displayCategory = item.category || '';
    if (displayCategory.toLowerCase().trim() === 'jar2') {
      displayCategory = 'jar';
    }
    const imgHtml = item.coverImage
      ? `<img src="${item.coverImage}" alt="${item.name}" width="300" height="300" style="width:100%;height:100%;object-fit:cover;" loading="lazy">`
      : '<div class="cream-fallback"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.5-.75-3-1.5-4.5.25 1 1.5 2 1.5 3.5s-1.25 2.5-2.5 3.5z"/><path d="M12 2C10 6 8 10 8 14c0 3.5 2 5 4 5s4-1.5 4-5c0-4-2-8-4-12z"/><circle cx="12" cy="14" r="3" fill="var(--warm-white)" opacity="0.3"/></svg></div>';
    return `<div class="product-card" onclick="window.openProductModal('${item.id}')">
      <div class="product-img">
        ${!item.stock || item.stock < 1 ? '<span class="badge-out">Out of Stock</span>' : ''}
        ${imgHtml}
      </div>
      <h3>${item.name}</h3><div class="scent">${displayCategory}</div><div class="price">₹${item.price}</div>
    </div>`;
  });
  productsGridHtml = cards.join('');
}

// SSR bestseller cards + scent guide HTML to eliminate CLS from JS injection
let bestsellerHtml = '';
let scentGridHtml = '';
if (initialCatalog?.inventory) {
  const sorted = [...initialCatalog.inventory].sort((a, b) => (b.totalSales || 0) - (a.totalSales || 0));
  const top5 = sorted.slice(0, 5);
  const reversed = [...top5].reverse();
  const arrowSvg = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>';
  const fireSvg = '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.5-.75-3-1.5-4.5.25 1 1.5 2 1.5 3.5s-1.25 2.5-2.5 3.5z"/><path d="M12 2C10 6 8 10 8 14c0 3.5 2 5 4 5s4-1.5 4-5c0-4-2-8-4-12z"/><circle cx="12" cy="14" r="3" fill="var(--warm-white)" opacity="0.3"/></svg>';
  bestsellerHtml = reversed.map((prod, idx) => {
    const rank = 5 - idx;
    const rankColor = rank === 1 ? 'var(--gold)' : 'var(--charcoal)';
    const rankTextColor = rank === 1 ? 'var(--black)' : 'var(--cream)';
    const displayCategory = (prod.category || '').toLowerCase().trim() === 'jar2' ? 'jar' : (prod.category || 'Luxury Scent');
    const imgHtml = prod.coverImage
      ? `<img src="${prod.coverImage}" alt="${prod.name}" width="300" height="300" style="width:100%;height:100%;object-fit:cover;">`
      : `<div class="cream-fallback">${fireSvg}</div>`;
    return `<div class="bestseller-card" style="--card-idx: ${idx}; z-index: ${10 + idx};" onclick="window.openProductModal('${prod.id}')"><div class="bestseller-card-content"><div class="bestseller-card-left"><span class="bestseller-rank-badge" style="background:${rankColor};color:${rankTextColor};">#${rank} Best Seller</span><h3>${prod.name}</h3><div class="bestseller-card-scent">${displayCategory}</div><p class="bestseller-card-desc">${prod.description ? prod.description.substring(0, 120) + '...' : 'Hand-poured 100% natural soya candle blended with botanical oils.'}</p><div class="bestseller-card-footer"><span class="bestseller-card-price">₹${prod.price}</span><span class="bestseller-card-cta">View Details ${arrowSvg}</span></div></div><div class="bestseller-card-right">${imgHtml}</div></div></div>`;
  }).join('');
}
if (initialCatalog?.fragrances && initialCatalog.fragrances.length > 0) {
  const colors = ['#F3E8DC,#EDE0D0', '#E8DDD0,#D4C4B0', '#F5EDE0,#EADCC8', '#F7F0E6,#EFE5D8', '#EDE5D8,#D4C4B0', '#F0E8DC,#E0D4C3'];
  const scentIcon = '<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--stone)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19h6a2 2 0 0 0 2-2v-3a5 5 0 0 0-10 0v3a2 2 0 0 0 2 2z"/><path d="M14 9h2v-2h-2z"/><path d="M13.5 7h3v-2h-3z"/><path d="M16.5 5.5h2.5"/><circle cx="20.5" cy="5.5" r="1.2" fill="var(--stone)"/><circle cx="9" cy="14.8" r="1.3" fill="var(--warm-white)"/><circle cx="9" cy="19.2" r="1.3" fill="var(--warm-white)"/><circle cx="11.2" cy="17" r="1.3" fill="var(--warm-white)"/><circle cx="6.8" cy="17" r="1.3" fill="var(--warm-white)"/><circle cx="10.6" cy="15.4" r="1.3" fill="var(--warm-white)"/><circle cx="10.6" cy="18.6" r="1.3" fill="var(--warm-white)"/><circle cx="7.4" cy="18.6" r="1.3" fill="var(--warm-white)"/><circle cx="7.4" cy="15.4" r="1.3" fill="var(--warm-white)"/><circle cx="9" cy="17" r="1" fill="var(--stone)"/></svg>';
  scentGridHtml = initialCatalog.fragrances.map((f, i) =>
    `<div class="scent-card" onclick="window.selectCategory('${encodeURIComponent(f)}')"><div class="scent-card-bg" style="background:linear-gradient(135deg,${colors[i % colors.length]});">${scentIcon}</div><h3>${f.charAt(0).toUpperCase() + f.slice(1)}</h3><p>Explore our ${f} scented candles — hand-poured with natural soya wax.</p></div>`
  ).join('');
}

// SSR page state — only show the correct section to eliminate CLS from section transitions
const initialPage = Astro.url.searchParams.get('page') || 'home';
const pages_list = ['home', 'shop', 'cartPage', 'payment', 'about', 'contact', 'ordersPage', 'addressesPage'];

const igPosts = Array.from({ length: 12 }, (_, i) => ({
  id: i + 1,
  gradient: [
    'linear-gradient(135deg,#EDE5D8,#D4C4B0)',
    'linear-gradient(135deg,#E8DDD0,#C4B5A0)',
    'linear-gradient(135deg,#F5EDE0,#E0D4C3)',
    'linear-gradient(135deg,#EDE5D8,#C4B5A0)',
    'linear-gradient(135deg,#F7F0E6,#D4C4B0)',
    'linear-gradient(135deg,#E8DDD0,#EDE0D0)'
  ][i % 6]
}));
---

<Layout>
  {heroImageUrl && <link rel="preload" as="image" href={heroImageUrl} fetchpriority="high" slot="head" />}
  <script is:inline slot="head">
  window.showPage = window.showPage || function showPage(pageId, updateHistory) {
    var _orig = window.showPage;
    window._pageQueue = window._pageQueue || [];
    window._pageQueue.push([pageId, updateHistory]);
    window.showPage = _orig;
  };
  window.handleBottomNavClick = window.handleBottomNavClick || function handleBottomNavClick(pageId, element) {
    window.showPage(pageId);
  };
  window.setCartType = function(type) {
    var highlight = document.getElementById('cartTypeHighlight');
    var normalText = document.getElementById('toggleNormal');
    var giftText = document.getElementById('toggleGift');
    if (!highlight || !normalText || !giftText) return;
    
    if (type === 'normal') {
      highlight.style.transform = 'translateX(0)';
      normalText.style.color = 'var(--black)';
      normalText.style.fontWeight = '600';
      giftText.style.color = 'var(--stone)';
      giftText.style.fontWeight = '500';
      sessionStorage.setItem('lumiere_cart_type', 'normal');
    } else {
      highlight.style.transform = 'translateX(62px)';
      normalText.style.color = 'var(--stone)';
      normalText.style.fontWeight = '500';
      giftText.style.color = 'var(--black)';
      giftText.style.fontWeight = '600';
      sessionStorage.setItem('lumiere_cart_type', 'gift');
    }
  };
  document.addEventListener('DOMContentLoaded', function() {
    var savedCartType = sessionStorage.getItem('lumiere_cart_type') || 'normal';
    setTimeout(function() {
      window.setCartType(savedCartType);
    }, 50);
  });
  </script>
  <div class="page-wrapper">
  <nav>
    <a href="#" class="nav-logo" onclick="event.preventDefault(); window.showPage('home')">Cozy<span>Aura</span></a>
    <button class="nav-hamburger" id="navHamburger" onclick="window.toggleMobileNav()" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
    <ul class="nav-links">
      <li><a href="#" onclick="event.preventDefault(); window.showPage('home')">Home</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('shop')">Shop</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('about')">About</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('contact')">Contact</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('wishlistPage')">Wishlist</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.showPage('ordersPage')">Your Orders</a></li>
    </ul>
    <div class="nav-right">
      <div class="nav-account-wrap">
        <button class="nav-account-btn" onclick="window.toggleAccountMenu()" id="navAccountBtn" title="Account"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></button>
        <div class="account-dropdown" id="accountDropdown">
          <div class="account-dropdown-header" id="dropdownUserInfo">Guest</div>
          <a href="#" onclick="event.preventDefault(); window.showPage('wishlistPage'); window.closeAccountMenu()">Wishlist</a>
          <a href="#" onclick="event.preventDefault(); window.showPage('ordersPage'); window.closeAccountMenu()">Your Orders</a>
          <a href="#" onclick="event.preventDefault(); window.showPage('addressesPage'); window.closeAccountMenu()">Saved Address</a>
          <a href="#" onclick="event.preventDefault(); window.showPage('contact'); window.closeAccountMenu()">Help & Support</a>
          <a href="#" onclick="event.preventDefault(); window.handleAccountDropdownAction();" id="dropdownLogout">Log Out</a>
        </div>
      </div>
      <button class="nav-cta" onclick="window.showPage('cartPage')">Checkout (0)</button>
    </div>
  </nav>
  <div class="mobile-nav-overlay" id="mobileNavOverlay" onclick="window.closeMobileNav(event)">
    <button class="mobile-nav-close" onclick="window.closeMobileNav()" aria-label="Close navigation menu"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
    <ul class="mobile-nav-links">
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('home')">Home</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('shop')">Shop</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('about')">About</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('contact')">Contact</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('wishlistPage')">Wishlist</a></li>
      <li><a href="#" onclick="event.preventDefault(); window.closeMobileNav(); window.showPage('ordersPage')">Your Orders</a></li>
    </ul>
  </div>

  <main>
  <section id="home" class={initialPage === 'home' ? 'active' : ''}>
    <div class="glow-orb orb-1"></div>
    <div class="glow-orb orb-2"></div>
    <div class="glow-orb orb-3"></div>
    <div class="hero-inner">
      <div class="hero-text">
        <span class="hero-subtitle">Meticulously Hand-Poured Soya Candles</span>
        <h1>Where<br><em>stillness</em><br>finds its flame.</h1>
        <p>Hand-poured 100% natural soya candles, crafted in small batches with botanically sourced fragrances. Clean, conscious, timeless.</p>
        <div class="hero-btns">
          <button class="btn-primary" onclick="window.showPage('shop')">Explore the Collection</button>
        </div>
      </div>
      <div class="hero-visual">
        <div class="hero-float-wrapper">
          <div class="hero-image-frame">
            <img src={heroImageUrl || ''} id="storefrontHeroImg" alt="Lumière Luxury Soya Candle" class="hero-img-element" width="380" height="480" fetchpriority="high" loading="eager" />
            <div class="hero-frame-glow"></div>
            <div class="hero-frame-border"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="home-section bestseller-sticky-section">
      <div class="bestseller-left">
        <div class="bestseller-sticky-header">
          <span class="bestseller-subtitle">Curated Favorites</span>
          <h2>Our<br><em>Bestsellers</em></h2>
          <p>Discover our most loved hand-poured creations, ranked by our community. Each blend is meticulously crafted to bring stillness and warmth to your space.</p>
          <button class="btn-primary" onclick="window.showPage('shop')">View All Collection</button>
        </div>
      </div>
      <div class="bestseller-right" id="bestsellerStickyContainer" data-ssr={bestsellerHtml ? '' : undefined} set:html={bestsellerHtml || '<p style="text-align:center;color:var(--stone);padding-top:4rem;">Loading...</p>'}></div>
    </div>

    <div class="home-section home-values">
      <div class="section-header" style="text-align:center;justify-content:center;">
        <h2>Why Cozy<em>Aura</em></h2>
      </div>
      <div class="values-grid">
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
          <h3>100% Natural Wax</h3>
          <p>Pure soya wax grown without pesticides, bleaching agents, or GMOs. Clean-burning from first light to last.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></div>
          <h3>Hand-Poured in India</h3>
          <p>Every candle is poured by hand in small batches in our Koregaon Park studio. Never mass-produced — always intentional.</p>
        </div>
        <div class="value-card">
          <div class="value-icon"><svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--gold)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="10" r="3"/></svg></div>
          <h3>Botanical Fragrances</h3>
          <p>Essential oil and botanical-based scents free of phthalates, parabens, and synthetic dyes. Made for mindful spaces.</p>
        </div>
      </div>
    </div>

    <div class="home-section home-scent-guide">
      <div class="section-header">
        <h2>Find Your <em>Scent</em></h2>
      </div>
      <div class="scent-grid" id="homeScentGrid" data-ssr={scentGridHtml ? '' : undefined} set:html={scentGridHtml || undefined}></div>
    </div>

    <div class="instagram-scroll-container" id="instagramScrollContainer">
      <div class="instagram-sticky-viewport">
        <div class="instagram-inner">
          <div class="instagram-header">
            <h2>Follow <em>Along</em></h2>
            <p style="font-size:0.88rem;color:var(--stone);font-weight:300;margin-top:0.5rem;font-family:'Jost',sans-serif;">Tag <strong>@cozyauracandles</strong> to be featured</p>
          </div>
          <div class="social-track-wrapper">
            <div class="social-track" id="socialTrack">
              {igPosts.map(post => (
                <a href="https://www.instagram.com/cozy_aura_candle/" target="_blank" rel="noopener noreferrer" class="social-post" aria-label="View Instagram post">
                  <div class="social-post-img" id={`ig-post-${post.id}`} style={`background:${post.gradient};display:flex;align-items:center;justify-content:center;`}>
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--taupe)" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                  </div>

                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="home-section home-testimonials">
      <div class="section-header" style="text-align:center;justify-content:center;">
        <h2>What Our <em>Customers</em> Say</h2>
      </div>
      <div class="testimonial-grid">
        <div class="testimonial-card">
          <div class="testimonial-stars">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <p>"The sandalwood candle is absolutely divine. It fills the entire room with a warm, grounding scent that lasts for hours. My new favourite ritual."</p>
          <span class="testimonial-author">— Ananya R.</span>
        </div>
          <div class="testimonial-card">
            <div class="testimonial-stars">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--gold)" stroke="var(--gold)" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
